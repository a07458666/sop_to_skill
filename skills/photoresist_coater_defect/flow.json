{
  "sop_name": "SOP: Photoresist Coater Defect Investigation Procedure",
  "start_state": "confirm_defect_signal",
  "states": [
    {
      "id": "confirm_defect_signal",
      "type": "action",
      "description": "Review inspection image, defect map, metrology result, and operator report to confirm a coating-related defect.",
      "tool": "inspection_result_lookup",
      "parameters": [
        "lot_id",
        "inspection_time"
      ],
      "next_states": {
        "coating defect is confirmed": "hold_affected_tool_and_lots",
        "defect is not coating related": "route_to_process_owner"
      }
    },
    {
      "id": "hold_affected_tool_and_lots",
      "type": "action",
      "description": "Put the coater module on engineering hold and hold affected lots for engineering disposition.",
      "tool": "containment_hold_request",
      "parameters": [
        "tool_id",
        "lot_ids",
        "hold_reason"
      ],
      "next_states": {
        "containment is complete": "review_coater_process_data",
        "containment fails": "escalate_to_manufacturing_lead"
      }
    },
    {
      "id": "review_coater_process_data",
      "type": "action",
      "description": "Review dispense pressure, spin speed, nozzle status, resist bottle lot, exhaust, and bake plate temperature.",
      "tool": "coater_process_data_review",
      "parameters": [
        "tool_id",
        "lot_ids",
        "recipe_id"
      ],
      "next_states": {
        "abnormal process signal is found": "run_coater_diagnostics",
        "no abnormal process signal is found": "review_material_history"
      }
    },
    {
      "id": "run_coater_diagnostics",
      "type": "action",
      "description": "Inspect dispense nozzle, pump calibration, cup cleanliness, track exhaust, and bake plate condition.",
      "tool": "coater_diagnostics",
      "parameters": [
        "tool_id",
        "module_id"
      ],
      "next_states": {
        "equipment issue is identified": "create_corrective_action",
        "equipment issue is not identified": "review_material_history"
      }
    },
    {
      "id": "review_material_history",
      "type": "action",
      "description": "Check resist bottle lot, expiration date, storage condition, filter change record, and chemical dispense history.",
      "tool": "material_history_review",
      "parameters": [
        "material_lot_id",
        "tool_id"
      ],
      "next_states": {
        "material issue is suspected": "open_mrb_case",
        "material issue is not suspected": "escalate_to_process_engineering"
      }
    },
    {
      "id": "create_corrective_action",
      "type": "action",
      "description": "Define cleaning, calibration, part replacement, or recipe correction action and assign an owner.",
      "tool": "corrective_action_create",
      "parameters": [
        "tool_id",
        "root_cause",
        "action_owner"
      ],
      "next_states": {
        "corrective action is approved": "verify_coater_recovery",
        "corrective action is rejected": "escalate_to_process_engineering"
      }
    },
    {
      "id": "verify_coater_recovery",
      "type": "action",
      "description": "Run monitor wafer coating test, review defect scan, and confirm thickness uniformity.",
      "tool": "coater_recovery_verify",
      "parameters": [
        "tool_id",
        "qualification_plan"
      ],
      "next_states": {
        "verification passes": "release_coater_to_production",
        "verification fails": "escalate_to_process_engineering"
      }
    },
    {
      "id": "release_coater_to_production",
      "type": "end_state",
      "description": "End state: Release tool and lots according to engineering disposition, then notify manufacturing.",
      "tool": null,
      "parameters": null,
      "next_states": null
    },
    {
      "id": "open_mrb_case",
      "type": "end_state",
      "description": "End state: Open MRB case for affected material or lots and notify quality and process owners.",
      "tool": null,
      "parameters": null,
      "next_states": null
    },
    {
      "id": "escalate_to_process_engineering",
      "type": "end_state",
      "description": "End state: Escalate with defect evidence, process data, material history, and containment status.",
      "tool": null,
      "parameters": null,
      "next_states": null
    },
    {
      "id": "escalate_to_manufacturing_lead",
      "type": "end_state",
      "description": "End state: Escalate containment failure to the manufacturing shift lead.",
      "tool": null,
      "parameters": null,
      "next_states": null
    },
    {
      "id": "route_to_process_owner",
      "type": "end_state",
      "description": "End state: Route the event to the responsible non-coating process owner with evidence attached.",
      "tool": null,
      "parameters": null,
      "next_states": null
    }
  ]
}